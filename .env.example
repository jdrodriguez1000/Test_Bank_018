# .env.example — Reservas Sala Comunitaria
# Copia este archivo a .env y rellena los valores reales.
# NUNCA commitees .env con valores reales.

# ---------------------------------------------------------------------------
# Base de datos
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=reservas_dev
POSTGRES_USER=reservas
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+psycopg2://reservas:changeme@localhost:5432/reservas_dev

# ---------------------------------------------------------------------------
# Auth JWT (D-A: jwt_backend)
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true
APP_CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Frontend (Next.js)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
